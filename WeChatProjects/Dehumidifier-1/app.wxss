/* app.wxss - 全局样式 */

page {
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  min-height: 100vh;
  color: #fff;
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', sans-serif;
}

/* 全局滚动条样式 */
::-webkit-scrollbar {
  width: 0;
  height: 0;
}

/* 防止页面滚动时出现白色背景 */
page {
  overflow-x: hidden;
}
