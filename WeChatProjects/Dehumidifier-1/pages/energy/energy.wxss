/* pages/energy/energy.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 30rpx;
  padding-bottom: 180rpx;
  box-sizing: border-box;
}

/* 顶部标题 */
.header {
  text-align: center;
  padding: 40rpx 0;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 10rpx;
}

/* 汇总卡片 */
.summary-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 40rpx rgba(102, 126, 234, 0.3);
}

.summary-header {
  margin-bottom: 24rpx;
}

.summary-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.summary-grid {
  display: flex;
  justify-content: space-between;
}

.summary-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  margin: 0 8rpx;
}

.summary-item:first-child {
  margin-left: 0;
}

.summary-item:last-child {
  margin-right: 0;
}

.summary-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}

.summary-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

.summary-unit {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 4rpx;
}

/* 实时数据卡片 */
.realtime-card {
  background: rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 24rpx;
}

.realtime-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}

.realtime-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 20rpx;
}

.realtime-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 16rpx;
}

.realtime-icon.voltage {
  background: rgba(255, 190, 11, 0.2);
}

.realtime-icon.current {
  background: rgba(78, 205, 196, 0.2);
}

.realtime-icon.power {
  background: rgba(255, 107, 107, 0.2);
}

.realtime-icon.energy {
  background: rgba(168, 85, 247, 0.2);
}

.realtime-info {
  flex: 1;
}

.realtime-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 6rpx;
}

.realtime-value {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}

.realtime-value .unit {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 400;
}

/* 时间选择器 */
.time-selector {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 30rpx;
}

.time-btn {
  padding: 16rpx 40rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 40rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 26rpx;
  transition: all 0.3s ease;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.time-btn.active {
  background: linear-gradient(135deg, #ffbe0b 0%, #fb5607 100%);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 8rpx 30rpx rgba(255, 190, 11, 0.3);
}

/* ★★★ 新增：模式图表卡片样式 ★★★ */
.chart-card {
  background: rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.chart-container {
  width: 100%;
  height: 400rpx; /* ECharts容器高度 */
}

/* echart 必须给宽高才能显示 */
ec-canvas {
  width: 100%;
  height: 100%;
  display: block;
}

.saving-tip {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 10rpx;
  padding: 20rpx;
  background: rgba(78, 205, 196, 0.1);
  border-radius: 16rpx;
  color: #4ecdc4;
  font-size: 26rpx;
}

.saving-icon {
  margin-right: 12rpx;
  font-size: 32rpx;
}

/* 每日能耗卡片 */
.daily-card {
  background: rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.daily-list {
  margin-top: 16rpx;
}

.daily-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.daily-item:last-child {
  border-bottom: none;
}

.daily-date {
  width: 120rpx;
}

.date-text {
  display: block;
  font-size: 26rpx;
  color: #fff;
  font-weight: 500;
}

.date-weekday {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 4rpx;
}

.daily-bar-container {
  flex: 1;
  height: 16rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 8rpx;
  margin: 0 20rpx;
  overflow: hidden;
}

.daily-bar {
  height: 100%;
  background: linear-gradient(90deg, #ffbe0b 0%, #fb5607 100%);
  border-radius: 8rpx;
  transition: width 0.5s ease;
}

.daily-value {
  width: 140rpx;
  text-align: right;
  font-size: 26rpx;
  color: #ffbe0b;
  font-weight: 600;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 节能提示卡片 */
.tips-card {
  background: rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
  padding: 30rpx;
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.tips-list {
  margin-top: 16rpx;
}

.tip-item {
  display: flex;
  align-items: center;
  padding: 16rpx 0;
}

.tip-icon {
  width: 40rpx;
  height: 40rpx;
  background: rgba(78, 205, 196, 0.2);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #4ecdc4;
  font-size: 24rpx;
  margin-right: 16rpx;
}

.tip-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.7);
}