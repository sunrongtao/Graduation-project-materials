/* pages/history/history.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 30rpx;
  padding-bottom: 180rpx;
  box-sizing: border-box;
}

/* 顶部标题 */
.header {
  text-align: center;
  padding: 40rpx 0;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 10rpx;
}

/* 时间范围选择器 */
.time-selector {
  display: flex;
  justify-content: center;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.time-btn {
  padding: 16rpx 36rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 40rpx;
  color: rgba(255, 255, 255, 0.7);
  font-size: 26rpx;
  transition: all 0.3s ease;
  border: 1px solid rgba(255, 255, 255, 0.1);
}

.time-btn.active {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  color: #fff;
  border-color: transparent;
  box-shadow: 0 8rpx 30rpx rgba(102, 126, 234, 0.4);
}

/* 统计卡片 */
.stats-row {
  display: flex;
  gap: 20rpx;
  margin-bottom: 40rpx;
}

.stat-card {
  flex: 1;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
  padding: 30rpx 20rpx;
  text-align: center;
  border: 1px solid rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(10px);
}

.stat-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 12rpx;
}

.stat-value {
  display: block;
  font-size: 36rpx;
  font-weight: 700;
  color: #fff;
}

/* 图表切换标签 */
.chart-tabs {
  display: flex;
  background: rgba(255, 255, 255, 0.06);
  border-radius: 20rpx;
  padding: 8rpx;
  margin-bottom: 30rpx;
}

.tab {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20rpx;
  border-radius: 16rpx;
  color: rgba(255, 255, 255, 0.5);
  font-size: 24rpx;
  transition: all 0.3s ease;
}

.tab.active {
  background: rgba(102, 126, 234, 0.3);
  color: #fff;
}

.tab-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

/* 图表容器 */
.chart-container {
  background: rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 40rpx;
  border: 1px solid rgba(255, 255, 255, 0.08);
  height: 550rpx;          /* 加上固定高度 */
  position: relative;      /* 加上 */
}


.chart-title {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
  margin-bottom: 20rpx;
}

/* ECharts画布 */
ec-canvas {
  width: 100%;
  height: 450rpx;
  display: block;
}

/* 数据列表 */
.data-list {
  background: rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
  padding: 30rpx;
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.list-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 24rpx;
}

.list-title {
  font-size: 28rpx;
  color: #fff;
  font-weight: 600;
}

.list-count {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

.list-scroll {
  max-height: 500rpx;
}

.list-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.list-item:last-child {
  border-bottom: none;
}

.item-time {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
}

.item-data {
  display: flex;
  gap: 16rpx;
}

.data-tag {
  padding: 8rpx 16rpx;
  border-radius: 12rpx;
  font-size: 22rpx;
  font-weight: 500;
}

.data-tag.temp {
  background: rgba(255, 107, 107, 0.2);
  color: #ff6b6b;
}

.data-tag.hum {
  background: rgba(78, 205, 196, 0.2);
  color: #4ecdc4;
}

.data-tag.water {
  background: rgba(69, 183, 209, 0.2);
  color: #45b7d1;
}

.data-tag.power {
  background: rgba(255, 190, 11, 0.2);
  color: #ffbe0b;
}

/* 空状态 */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 80rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 加载状态 */
.loading-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
}

.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.1);
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
  margin-top: 24rpx;
}
