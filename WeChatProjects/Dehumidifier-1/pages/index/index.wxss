/* pages/index/index.wxss */
.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 30rpx;
  padding-bottom: 180rpx;
  box-sizing: border-box;
}

/* 顶部标题 */
.header {
  text-align: center;
  padding: 40rpx 0;
}
.title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
}
.status-row {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 12rpx;
}
.status-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  margin-right: 10rpx;
}
.status-dot.online { background: #4ecdc4; box-shadow: 0 0 8rpx #4ecdc4; }
.status-dot.offline { background: #ff6b6b; box-shadow: 0 0 8rpx #ff6b6b; }
.subtitle {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
}

/* 温湿度汇总卡片 */
.summary-card {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  box-shadow: 0 10rpx 40rpx rgba(102, 126, 234, 0.3);
}
.summary-header { margin-bottom: 24rpx; }
.summary-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}
.summary-grid {
  display: flex;
  justify-content: space-between;
}
.summary-item {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 16rpx;
  margin: 0 8rpx;
}
.summary-item:first-child { margin-left: 0; }
.summary-item:last-child { margin-right: 0; }
.summary-label {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
  margin-bottom: 8rpx;
}
.summary-value {
  display: block;
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
}
.summary-unit {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 4rpx;
}

/* 通用卡片 */
.card {
  background: rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border: 1px solid rgba(255, 255, 255, 0.08);
}
.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 24rpx;
}

/* 水箱 */
.water-section {
  display: flex;
  align-items: center;
}
.water-bar-bg {
  flex: 1;
  height: 24rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  overflow: hidden;
  margin-right: 24rpx;
}
.water-bar-fill {
  height: 100%;
  border-radius: 12rpx;
  transition: width 0.5s ease;
}
.water-info { text-align: right; }
.water-percent {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #4ecdc4;
}
.water-raw {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 实时电能 */
.realtime-grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20rpx;
}
.realtime-item {
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.05);
  border-radius: 16rpx;
  padding: 20rpx;
}
.realtime-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-right: 16rpx;
}
.realtime-icon.voltage { background: rgba(255, 190, 11, 0.2); }
.realtime-icon.current { background: rgba(78, 205, 196, 0.2); }
.realtime-icon.power { background: rgba(255, 107, 107, 0.2); }
.realtime-icon.energy { background: rgba(168, 85, 247, 0.2); }
.realtime-info { flex: 1; }
.realtime-label {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 6rpx;
}
.realtime-value {
  display: block;
  font-size: 32rpx;
  font-weight: 600;
  color: #fff;
}
.realtime-value .unit {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.5);
  font-weight: 400;
}

/* 设备控制 */
.control-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}
.control-item:last-child { border-bottom: none; }
.smart-highlight {
  background: rgba(78, 205, 196, 0.08);
  padding: 24rpx;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  border-bottom: none;
}
.control-info {
  display: flex;
  align-items: center;
}
.control-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
}
.control-text { flex: 1; }
.control-label {
  display: block;
  font-size: 28rpx;
  color: #fff;
}
.control-sub {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
  margin-top: 4rpx;
}
.mode-desc {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.6);
  background: rgba(78, 205, 196, 0.08);
  padding: 20rpx;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  line-height: 1.6;
}

/* 加载状态 */
.loading-mask {
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.7);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  z-index: 999;
}
.loading-spinner {
  width: 80rpx;
  height: 80rpx;
  border: 6rpx solid rgba(255, 255, 255, 0.1);
  border-top-color: #667eea;
  border-radius: 50%;
  animation: spin 1s linear infinite;
}
@keyframes spin { to { transform: rotate(360deg); } }
.loading-text {
  color: rgba(255, 255, 255, 0.8);
  font-size: 28rpx;
  margin-top: 24rpx;
}