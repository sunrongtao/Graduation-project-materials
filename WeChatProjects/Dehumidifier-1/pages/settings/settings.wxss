/* pages/settings/settings.wxss */

.container {
  min-height: 100vh;
  background: linear-gradient(180deg, #1a1a2e 0%, #16213e 50%, #0f3460 100%);
  padding: 30rpx;
  padding-bottom: 180rpx;
  box-sizing: border-box;
}

/* 顶部标题 */
.header {
  text-align: center;
  padding: 40rpx 0;
}

.title {
  display: block;
  font-size: 48rpx;
  font-weight: 700;
  color: #fff;
  letter-spacing: 4rpx;
}

.subtitle {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-top: 10rpx;
}

/* 通用卡片 */
.card {
  background: rgba(255, 255, 255, 0.06);
  border-radius: 24rpx;
  padding: 30rpx;
  margin-bottom: 30rpx;
  border: 1px solid rgba(255, 255, 255, 0.08);
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 24rpx;
}

/* 信息列表 */
.info-list {
  margin-top: 16rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.info-value {
  font-size: 28rpx;
  color: #fff;
}

.info-arrow {
  font-size: 36rpx;
  color: rgba(255, 255, 255, 0.3);
}

/* 状态标签 */
.status-badge {
  padding: 8rpx 20rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
}

.status-badge.online {
  background: rgba(78, 205, 196, 0.2);
  color: #4ecdc4;
}

.status-badge.offline {
  background: rgba(255, 107, 107, 0.2);
  color: #ff6b6b;
}

/* 设置列表 */
.setting-list {
  margin-top: 16rpx;
}

.setting-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 24rpx 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.setting-item:last-child {
  border-bottom: none;
}

.setting-info {
  flex: 1;
}

.setting-label {
  display: block;
  font-size: 28rpx;
  color: #fff;
  margin-bottom: 6rpx;
}

.setting-desc {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.4);
}

/* 阈值设置 */
.threshold-list {
  margin-top: 16rpx;
}

.threshold-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1px solid rgba(255, 255, 255, 0.06);
}

.threshold-item:last-child {
  border-bottom: none;
}

.threshold-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.7);
}

.threshold-control {
  display: flex;
  align-items: center;
  gap: 20rpx;
}

.btn-minus,
.btn-plus {
  width: 60rpx;
  height: 60rpx;
  background: rgba(255, 255, 255, 0.1);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  color: #fff;
}

.btn-minus:active,
.btn-plus:active {
  background: rgba(102, 126, 234, 0.5);
}

.threshold-value {
  min-width: 100rpx;
  text-align: center;
  font-size: 32rpx;
  font-weight: 600;
  color: #667eea;
}

/* 服务器设置 */
.server-setting {
  margin-top: 16rpx;
}

.server-setting .setting-label {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.6);
  margin-bottom: 16rpx;
}

.server-input {
  background: rgba(255, 255, 255, 0.08);
  border: 1px solid rgba(255, 255, 255, 0.1);
  border-radius: 12rpx;
  padding: 20rpx;
  color: #fff;
  font-size: 28rpx;
  margin-bottom: 20rpx;
}

.server-input::placeholder {
  color: rgba(255, 255, 255, 0.3);
}

.btn-save {
  background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
  border-radius: 12rpx;
  padding: 20rpx;
  text-align: center;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
}

.btn-save:active {
  opacity: 0.8;
}

/* 底部版权 */
.footer {
  text-align: center;
  padding: 40rpx 0;
  margin-top: 20rpx;
}

.footer-text {
  display: block;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.5);
  margin-bottom: 8rpx;
}

.footer-copyright {
  display: block;
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.3);
}
